# ═══════════════════════════════════════
#  MediRoute 백엔드 환경변수
#  이 파일을 .env 로 복사 후 실제 값을 입력하세요
#  cp .env.example .env
# ═══════════════════════════════════════

# ── 앱 설정 ──
DEBUG=true

# ── Claude API (필수) ──
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── 프론트엔드 URL (CORS) ──
FRONTEND_URL=http://localhost:5500

# ── 공공데이터 API (STEP 2에서 사용, 지금은 비워두기) ──
DATA_GO_KR_API_KEY=
KAKAO_REST_API_KEY=

# ── DB (STEP 4, SQLite는 기본값 사용) ──
# DATABASE_URL=sqlite:///./mediroute.db
# PostgreSQL 배포 시: DATABASE_URL=postgresql://user:pass@host:5432/mediroute

# ── JWT 비밀키 (운영 시 반드시 변경!) ──
JWT_SECRET_KEY=mediroute-dev-secret-change-in-production

# ── 카카오 OAuth (STEP 4) ──
KAKAO_CLIENT_ID=

# ── 네이버 OAuth (STEP 4) ──
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
