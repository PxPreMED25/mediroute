# ═══════════════════════════════════════
#  MediRoute 백엔드 환경변수
#  이 파일을 .env 로 복사 후 실제 값을 입력하세요
#  cp .env.example .env
# ═══════════════════════════════════════

# ── 앱 설정 ──
DEBUG=true

# ── Claude API (필수) ──
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── 프론트엔드 URL (CORS) ──
FRONTEND_URL=http://localhost:5500

# ── 병원 검색 API 키: 실제 값은 Render/Railway 환경변수에만 입력 ──
DATA_GO_KR_API_KEY=
KAKAO_REST_API_KEY=

# ── 네이버 지역검색/지도 API ──
# 가까운 병원 검색을 네이버 기준으로 처리하려면 아래 값을 설정하세요.
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
NAVER_MAPS_CLIENT_ID=
NAVER_MAPS_CLIENT_SECRET=

# ── DB (STEP 4, SQLite는 기본값 사용) ──
# DATABASE_URL=sqlite:///./mediroute.db
# PostgreSQL 배포 시: DATABASE_URL=postgresql://user:pass@host:5432/mediroute

# ── JWT 비밀키 (운영 시 반드시 변경!) ──
JWT_SECRET_KEY=mediroute-dev-secret-change-in-production

# ── 카카오 OAuth (STEP 4) ──
KAKAO_CLIENT_ID=

# ── 네이버 OAuth (STEP 4) ──
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 병원 검색 우선순위
# provider=auto: 네이버 지역검색/지도 API → 카카오 Local API → HIRA 병원정보 API 순서로 검색합니다.
# GitHub 소스코드에는 실제 키를 절대 넣지 마세요.
